{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "nono",
      "camelcase": "Nono",
      "scope": "source.nono",
      "file-types": ["nono"],
      "highlights": ["queries/highlights.scm"],
      "injection-regex": "^nono$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Nono, the spite-driven static site generator's DSL",
    "authors": [
      {
        "name": "Dave Mackintosh"
      }
    ],
    "links": {
      "repository": "https://github.com/davemackintosh/nono"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
